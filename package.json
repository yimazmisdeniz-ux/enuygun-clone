{
  "name": "ai-website-clone-template",
  "version": "0.3.1",
  "private": true,
  "description": "Clone any website into a clean, modern Next.js codebase using AI coding agents",
  "author": "JCodesMore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JCodesMore/ai-website-cloner-template.git"
  },
  "homepage": "https://github.com/JCodesMore/ai-website-cloner-template",
  "bugs": {
    "url": "https://github.com/JCodesMore/ai-website-cloner-template/issues"
  },
  "keywords": [
    "claude-code",
    "website-clone",
    "reverse-engineering",
    "nextjs",
    "ai",
    "template",
    "tailwindcss",
    "shadcn-ui"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --experimental-https --experimental-https-key localhost-key.pem --experimental-https-cert localhost.pem --webpack",
    "build": "next build && node scripts/secure-build.mjs",
    "build:netlify": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "scrape:discover": "tsx scripts/scraper/discover/capture-napi.ts",
    "scrape:hotels": "tsx scripts/scraper/hotels/01-enumerate.ts && tsx scripts/scraper/hotels/02-detail.ts",
    "scrape:prices": "tsx scripts/scraper/hotels/03-prices.ts",
    "scrape:reviews": "tsx scripts/scraper/hotels/04-reviews.ts",
    "scrape:cars": "tsx scripts/scraper/cars/01-enumerate.ts && tsx scripts/scraper/cars/02-detail.ts",
    "ingest": "tsx scripts/scraper/ingest/upsert.ts",
    "translate": "tsx scripts/translate/translate-content.ts",
    "realism": "tsx scripts/seed-realism/realism.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.12",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "fast-xml-parser": "^5.8.0",
    "p-limit": "^7.3.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
